# ClarioDesk Production Environment
# Copy to deploy/.env and fill in real values before deploying.
# Generate secrets: openssl rand -base64 48
# NEVER commit this file with real values.

# ── Core ───────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ── PostgreSQL ─────────────────────────────────────────────────────────
POSTGRES_DB=clariodesk
POSTGRES_USER=clariodesk
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

DATABASE_URL=postgres://clariodesk:CHANGE_ME_strong_password_here@postgres:5432/clariodesk

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Object storage (MinIO) ─────────────────────────────────────────────
MINIO_USER=clariodesk
MINIO_PASSWORD=CHANGE_ME_strong_minio_password

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=clariodesk
S3_SECRET_ACCESS_KEY=CHANGE_ME_strong_minio_password
S3_BUCKET_MEDIA=clariodesk-media
S3_BUCKET_RAW_EVENTS=clariodesk-raw-events
S3_FORCE_PATH_STYLE=true

# ── Auth ───────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_run_openssl_rand_base64_48
JWT_EXPIRES_IN=7d

# ── Encryption (secrets at rest) ───────────────────────────────────────
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME_run_openssl_rand_base64_32

# ── CORS ───────────────────────────────────────────────────────────────
# Comma-separated list of your frontend origin(s)
CORS_ORIGINS=https://your-domain.com

# ── API ────────────────────────────────────────────────────────────────
API_PORT=4000
# Generate: openssl rand -base64 32
GATEWAY_WEBHOOK_SECRET=CHANGE_ME_run_openssl_rand_base64_32

# ── Gateway ────────────────────────────────────────────────────────────
CLARIO_GATEWAY_BASE_URL=http://gateway:2786
CLARIO_GATEWAY_PORT=2786
# Generate: openssl rand -base64 32
CLARIO_GATEWAY_API_KEY=CHANGE_ME_run_openssl_rand_base64_32
CLARIO_GATEWAY_DATA_DIR=/data/gateway
CLARIO_API_WEBHOOK_BASE_URL=http://api:4000/api
CLARIO_GATEWAY_WEBHOOK_SECRET=CHANGE_ME_same_as_GATEWAY_WEBHOOK_SECRET

# ── Safety thresholds ──────────────────────────────────────────────────
STALE_SYNC_THRESHOLD_SECONDS=900
SEND_DELAY_MS=3000
