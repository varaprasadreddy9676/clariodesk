# ── Core ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── PostgreSQL ─────────────────────────────────────────────────────────
DATABASE_URL=postgres://clariodesk:clariodesk@localhost:5432/clariodesk

# ── Redis / BullMQ ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Object storage (S3 / MinIO) ────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=clariodesk
S3_SECRET_ACCESS_KEY=clariodesk-secret
S3_BUCKET_MEDIA=clariodesk-media
S3_BUCKET_RAW_EVENTS=clariodesk-raw-events
S3_FORCE_PATH_STYLE=true

# ── Auth ───────────────────────────────────────────────────────────────
# Must be at least 32 chars in production.
JWT_SECRET=dev-only-change-me-32-chars-minimum-secret
JWT_EXPIRES_IN=7d

# ── Encryption (secrets at rest) ───────────────────────────────────────
# base64-encoded 32-byte key for AES-256-GCM. Generate: openssl rand -base64 32
# The value below is a DEV default and is rejected in production.
ENCRYPTION_KEY=AQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQE=

# Comma-separated CORS allowlist (e.g. https://app.example.com). Empty = reflect in dev.
CORS_ORIGINS=

# ── API ────────────────────────────────────────────────────────────────
API_PORT=4000
# Shared secret the gateway must present on the webhook endpoint.
GATEWAY_WEBHOOK_SECRET=dev-gateway-webhook-secret

# ── ClarioDesk first-party linked-device gateway ───────────────────────
# Run with: npm run -w @clariodesk/gateway start
CLARIO_GATEWAY_BASE_URL=http://localhost:2786
CLARIO_GATEWAY_PORT=2786
CLARIO_GATEWAY_API_KEY=dev-clario-gateway-key
CLARIO_GATEWAY_DATA_DIR=./.clario-gateway
# Gateway posts live messages to `${CLARIO_API_WEBHOOK_BASE_URL}/gateway-webhooks/...`
CLARIO_API_WEBHOOK_BASE_URL=http://localhost:4000/api
CLARIO_GATEWAY_WEBHOOK_SECRET=dev-gateway-webhook-secret

# ── Safety thresholds (P0) ─────────────────────────────────────────────
# Messages older than this (seconds) on reconnect are treated as stale sync.
STALE_SYNC_THRESHOLD_SECONDS=900
# Send-delay window in milliseconds (the "undo" window — NOT true undo).
SEND_DELAY_MS=3000
